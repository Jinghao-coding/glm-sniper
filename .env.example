# =============================================================
# GLM Coding Plan 抢购脚本 配置
# 复制此文件为 .env 并填入你的配置
# =============================================================

# ---------- 认证 ----------
# JWT Authorization Token。获取方式：
#   F12 → Network → 找到任意 /api/biz/ 请求 → Request Headers → 复制 authorization 的值
AUTHORIZATION="your-jwt-token-here"

# Cookie 备用（部分接口只需要 cookie）
# F12 → Application → Cookies → bigmodel.cn → 复制所有 cookie 拼接
COOKIE_STRING=""

# ---------- 目标套餐 ----------
# 要抢购的套餐 productId。在开售时访问页面获取最新的 productId：
#   F12 → Console 执行:
#     fetch('/api/biz/pay/batch-preview',{method:'POST',headers:{'Content-Type':'application/json','Authorization':document.querySelector('meta')?.content||''},body:'{"invitationCode":""}',credentials:'include'}).then(r=>r.json()).then(d=>console.table(d.data.productList.map(p=>({name:p.monthlyOriginalAmount+'/月',id:p.productId,pay:p.payAmount}))))
# 常用套餐 productId 格式: product-xxxxxx
PRODUCT_ID="product-1df3e1"

# 邀请码（可选，用于拼团折扣）
INVITATION_CODE=""

# ---------- 并发配置 ----------
TURBO_CONCURRENCY=10
NORMAL_CONCURRENCY=5
TURBO_DURATION=5
MAX_RETRY=2000

# ---------- 定时配置 ----------
RUSH_TIME="10:00:00"
PREHEAT_BEFORE=3

# ---------- 网络配置 ----------
REQUEST_TIMEOUT=10
CONNECTION_POOL_SIZE=50
WARMUP_COUNT=5

# ---------- 通知配置 ----------
PLAY_SOUND=true
DESKTOP_NOTIFY=true
